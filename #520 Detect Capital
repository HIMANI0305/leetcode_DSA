class Solution {
    public boolean detectCapitalUse(String word) {
        int caps = 0;

        for (int i = 0; i < word.length(); i++) {
            char c = word.charAt(i);
            if (c >= 'A' && c <= 'Z') {
                caps++;
            }
        }

        return caps == word.length() || caps == 0 || 
               (caps == 1 && word.charAt(0) >= 'A' && word.charAt(0) <= 'Z');
    }
}
